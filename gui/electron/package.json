{
  "name": "entrascope-gui",
  "version": "1.0.0",
  "description": "EntraScope — Azure & M365 Entra Penetration Testing Toolkit GUI",
  "main": "src/main.js",
  "author": "EntraScope",
  "license": "MIT",
  "private": true,

  "scripts": {
    "start":   "electron .",
    "dev":     "cross-env NODE_ENV=development electron .",
    "build":   "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "lint":    "eslint src/**/*.js",
    "clean":   "rimraf dist out"
  },

  "dependencies": {
    "electron-store":  "^8.2.0",
    "ps-list":         "^8.1.1",
    "node-pty":        "^1.0.0",
    "xterm":           "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "chart.js":        "^4.4.3",
    "marked":          "^12.0.0",
    "chokidar":        "^3.6.0"
  },

  "devDependencies": {
    "electron":             "^31.0.0",
    "electron-builder":     "^24.13.3",
    "cross-env":            "^7.0.3",
    "eslint":               "^9.5.0",
    "rimraf":               "^5.0.7"
  },

  "build": {
    "appId":       "com.entrascope.gui",
    "productName": "EntraScope",
    "icon":        "assets/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick":            false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from":   "../../",
        "to":     "entrascope",
        "filter": ["**/*.ps1", "config/**", "modules/**"]
      }
    ],
    "files": [
      "src/**",
      "assets/**",
      "node_modules/**"
    ]
  }
}
